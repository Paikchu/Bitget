BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSPHRASE=

# Unified CCXT symbol for USDT-M perpetual (example)
SYMBOL=BTC/USDT:USDT
TIMEFRAME=15m

# Safe default: log only, no orders
DRY_RUN=true

LEVERAGE=5
MARGIN_USAGE_PCT=100

SQUEEZE_THRESHOLD=0.35

# Dashboard / DB settings
INITIAL_EQUITY=10000      # Starting equity for the equity curve tracker (USDT)
DB_PATH=data/bot.db       # SQLite database path (relative to project root)

# Pine defines NY weekday but never uses it. Set true to skip Sat/Sun (America/New_York) on entries/exits.
APPLY_NY_WEEKDAY_FILTER=false
