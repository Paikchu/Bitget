# ── Bitget API credentials (required for live trading) ──────────
BITGET_API_KEY=your_api_key_here
BITGET_API_SECRET=your_api_secret_here
BITGET_API_PASSPHRASE=your_passphrase_here

# ── Trading parameters ──────────────────────────────────────────
SYMBOL=BTC/USDT:USDT
TIMEFRAME=15m
DRY_RUN=true
LEVERAGE=5
MARGIN_USAGE_PCT=100.0
SQUEEZE_THRESHOLD=0.35

# ── Initial equity (used for P&L tracking in dry run mode) ──────
INITIAL_EQUITY=10000.0

# ── Database ────────────────────────────────────────────────────
DB_PATH=data/bot.db

# ── Bot poll interval (seconds) ─────────────────────────────────
POLL_INTERVAL=60
